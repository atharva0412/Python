salary = int(input("Enter the salary of the employee:"))
ch = input("Enter the sex of the employee (m or f):")
if(ch == 'm'):
    bonus = 0.05 * salary
else:
    bonus = 0.10 * salary
    
print("Employee's regular salary is:", salary)

if(salary < 10000):
    bonus = bonus + 0.02 * salary
else:
    bonus = bonus
    
total_salary = salary + bonus
    
print("Employee's salary with bonus for salary greater than 10000:", total_salary)
